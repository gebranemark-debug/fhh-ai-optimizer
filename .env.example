# FHH AI Optimizer — environment variables
#
# Copy this file to `.env` (which is gitignored) and fill in your real values.
# `.env` is NEVER committed to git. See backend/postgres/README.md for usage.

# -- Postgres (Supabase) -----------------------------------------------------
# Get this from Supabase: Project Settings -> Database -> Connection string
# -> "URI" tab. Replace YOUR-PASSWORD and YOUR-PROJECT-REF below.
#
# Format:
#   postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
#
# Supabase enforces SSL; SQLAlchemy + psycopg2 negotiate it automatically.
# If you ever hit SSL errors, append ?sslmode=require to the URL.
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
